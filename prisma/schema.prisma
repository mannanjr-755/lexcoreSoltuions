// Lexcore Solutions ERP/CRM — Prisma schema (Neon PostgreSQL)
generator client {
  provider      = "prisma-client-js"
  // native = local/dev; rhel-openssl-3.0.x = Netlify AWS Lambda (Amazon Linux 2023)
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  // Runtime / serverless (Neon pooler URL recommended)
  url       = env("DATABASE_URL")
  // Migrations (Neon direct / non-pooler URL — set automatically from DATABASE_URL if omitted)
  directUrl = env("DIRECT_URL")
}

enum Role {
  super_admin
  admin
  manager
  employee
  accountant
  customer
}

enum CustomerStatus {
  lead
  active
  on_hold
  completed
  cancelled
}

enum Priority {
  low
  medium
  high
  urgent
}

enum ProjectStatus {
  pending
  active
  on_hold
  completed
  cancelled
}

enum TaskStatus {
  todo
  in_progress
  review
  done
  cancelled
}

enum EmployeeStatus {
  active
  inactive
  on_leave
}

enum AttendanceStatus {
  present
  absent
  late
  half_day
  leave
  work_from_home
}

enum PaymentStatus {
  pending
  paid
  partial
  overdue
  cancelled
}

enum PaymentMethod {
  cash
  bank
  card
  online
}

enum ExpenseCategory {
  office
  marketing
  hosting
  software
  electricity
  internet
  transport
  miscellaneous
}

enum QuotationStatus {
  draft
  sent
  accepted
  rejected
  expired
}

enum PayrollStatus {
  draft
  processed
  paid
}

enum DocumentCategory {
  contract
  invoice
  proposal
  policy
  other
}

enum NotificationType {
  info
  success
  warning
  danger
  project
  invoice
  customer
  task
}

enum DepartmentStatus {
  active
  inactive
}

enum ThemeMode {
  dark
  light
}

model User {
  id                   String    @id @default(cuid())
  fullName             String
  email                String    @unique
  passwordHash         String
  role                 Role      @default(employee)
  phone                String?
  profilePhoto         String?
  company              String    @default("Lexcore Solutions")
  designation          String    @default("Super Admin")
  address              String?
  isActive             Boolean   @default(true)
  failedLoginAttempts  Int       @default(0)
  lockedUntil          DateTime?
  lastLoginAt          DateTime?
  lastLoginIp          String?
  otpCode              String?
  otpExpiresAt         DateTime?
  otpVerified          Boolean   @default(false)
  passwordResetToken   String?
  passwordResetExpires DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  assignedCustomers Customer[]      @relation("CustomerManager")
  employeeProfile   Employee?
  ledProjects       Project[]       @relation("ProjectLeader")
  expensesCreated   Expense[]       @relation("ExpenseCreator")
  documentsUploaded Document[]      @relation("DocumentUploader")
  notifications     Notification[]
  activityLogs      ActivityLog[]
  loginHistory      LoginHistory[]
  refreshTokens     RefreshToken[]
  sessions          Session[]
  otps              Otp[]

  @@index([role, createdAt])
  @@map("users")
}

model Customer {
  id              String         @id @default(cuid())
  customerId      String         @unique
  name            String
  phone           String
  whatsapp        String?
  email           String
  company         String?
  address         String?
  projectName     String
  projectType     String
  technology      String[]       @default([])
  assignedManager String
  manager         User           @relation("CustomerManager", fields: [assignedManager], references: [id], onDelete: Restrict)
  totalCost       Float
  advancePaid     Float          @default(0)
  paidAmount      Float          @default(0)
  remainingAmount Float
  projectDeadline DateTime
  priority        Priority       @default(medium)
  status          CustomerStatus @default(lead)
  notes           String?
  documents       String[]       @default([])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  projects   Project[]
  payments   Payment[]
  quotations Quotation[]
  files      Document[]

  @@index([status, projectDeadline])
  @@index([assignedManager, status])
  @@index([name])
  @@index([email])
  @@map("customers")
}

model Employee {
  id                    String         @id @default(cuid())
  userId                String?        @unique
  user                  User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  employeeId            String         @unique
  fullName              String
  email                 String
  phone                 String?
  cnic                  String?
  department            String
  position              String
  salary                Float          @default(0)
  photo                 String?
  status                EmployeeStatus @default(active)
  joinDate              DateTime       @default(now())
  attendancePercentage  Float          @default(100)
  isArchived            Boolean        @default(false)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  tasks      Task[]
  attendance Attendance[]
  payrolls   Payroll[]

  @@index([department])
  @@index([status])
  @@index([isArchived])
  @@map("employees")
}

model Project {
  id                String        @id @default(cuid())
  name              String
  customerId        String
  customer          Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  description       String?
  status            ProjectStatus @default(pending)
  priority          Priority      @default(medium)
  progress          Int           @default(0)
  totalTasks        Int           @default(0)
  completedTasks    Int           @default(0)
  budget            Float         @default(0)
  spent             Float         @default(0)
  teamLeaderId      String?
  teamLeader        User?         @relation("ProjectLeader", fields: [teamLeaderId], references: [id], onDelete: SetNull)
  assignedEmployees String[]      @default([])
  deadline          DateTime
  technologies      String[]      @default([])
  isArchived        Boolean       @default(false)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  tasks     Task[]
  payments  Payment[]
  documents Document[]

  @@index([status, deadline])
  @@index([customerId])
  @@index([isArchived])
  @@map("projects")
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  projectId   String?
  project     Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assigneeId  String?
  assignee    Employee?  @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  status      TaskStatus @default(todo)
  priority    Priority   @default(medium)
  dueDate     DateTime?
  isArchived  Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status])
  @@index([projectId])
  @@index([assigneeId])
  @@index([isArchived])
  @@map("tasks")
}

model Payment {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  customerId    String
  customer      Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  projectId     String?
  project       Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  amount        Float
  tax           Float         @default(0)
  discount      Float         @default(0)
  grandTotal    Float
  status        PaymentStatus @default(pending)
  paymentMethod PaymentMethod @default(bank)
  paidAt        DateTime?
  dueDate       DateTime
  notes         String?
  isArchived    Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
  @@index([customerId])
  @@index([isArchived])
  @@map("payments")
}

model Expense {
  id          String          @id @default(cuid())
  title       String
  category    ExpenseCategory
  amount      Float
  description String?
  date        DateTime
  createdById String?
  createdBy   User?           @relation("ExpenseCreator", fields: [createdById], references: [id], onDelete: SetNull)
  isArchived  Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([date, category])
  @@index([isArchived])
  @@map("expenses")
}

model Attendance {
  id           String           @id @default(cuid())
  employeeId   String
  employee     Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeName String
  department   String           @default("")
  date         DateTime
  dateKey      String
  status       AttendanceStatus @default(present)
  checkIn      String           @default("")
  checkOut     String           @default("")
  workingHours Float            @default(0)
  remarks      String           @default("")
  notes        String           @default("")
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([employeeId, dateKey])
  @@index([dateKey])
  @@index([status])
  @@index([department])
  @@map("attendances")
}

model Payroll {
  id          String        @id @default(cuid())
  employeeId  String
  employee    Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  month       Int
  year        Int
  basicSalary Float
  allowances  Float         @default(0)
  deductions  Float         @default(0)
  netSalary   Float
  status      PayrollStatus @default(draft)
  paidAt      DateTime?
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([employeeId, month, year])
  @@map("payrolls")
}

model Department {
  id            String           @id @default(cuid())
  name          String           @unique
  code          String           @default("")
  description   String           @default("")
  managerName   String           @default("")
  status        DepartmentStatus @default(active)
  employeeCount Int              @default(0)
  isArchived    Boolean          @default(false)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([status])
  @@map("departments")
}

model Document {
  id           String           @id @default(cuid())
  title        String
  category     DocumentCategory @default(other)
  fileUrl      String
  customerId   String?
  customer     Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  projectId    String?
  project      Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  uploadedById String?
  uploadedBy   User?            @relation("DocumentUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  notes        String?
  isArchived   Boolean          @default(false)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([category])
  @@index([isArchived])
  @@map("documents")
}

model Quotation {
  id              String          @id @default(cuid())
  quotationNumber String          @unique
  customerId      String
  customer        Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  title           String
  amount          Float
  tax             Float           @default(0)
  discount        Float           @default(0)
  grandTotal      Float
  status          QuotationStatus @default(draft)
  validUntil      DateTime
  notes           String?
  isArchived      Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([status])
  @@index([customerId])
  @@map("quotations")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      NotificationType @default(info)
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([userId, isRead, createdAt])
  @@map("notifications")
}

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userName    String
  action      String
  entity      String?
  entityId    String?
  description String
  ipAddress   String?
  userAgent   String?
  browser     String?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdAt])
  @@index([userId, createdAt])
  @@map("activity_logs")
}

model LoginHistory {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress     String
  userAgent     String
  browser       String?
  success       Boolean
  failureReason String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId, createdAt])
  @@map("login_histories")
}

model SystemSettings {
  id                     String    @id @default(cuid())
  companyName            String    @default("Lexcore Solutions")
  companyLogo            String?
  companyAddress         String?
  companyEmail           String?
  companyPhone           String?
  companyWebsite         String?   @default("https://lexcore.com")
  smtpHost               String?
  smtpPort               Int       @default(587)
  smtpUser               String?
  smtpPass               String?
  smtpFrom               String?
  currency               String    @default("USD")
  timezone               String    @default("UTC")
  language               String    @default("en")
  theme                  ThemeMode @default(light)
  backupEnabled          Boolean   @default(false)
  backupSchedule         String    @default("0 2 * * *")
  sessionTimeoutMinutes  Int       @default(30)
  maxLoginAttempts       Int       @default(5)
  lockoutDurationMinutes Int       @default(30)
  dashboardLayout        Json      @default("{}")
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@map("system_settings")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@map("refresh_tokens")
}

model Session {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash    String    @unique
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  revokedAt    DateTime?
  lastActiveAt DateTime  @default(now())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
  @@map("sessions")
}

model Otp {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      String
  purpose   String   @default("password_reset")
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, purpose])
  @@map("otps")
}
